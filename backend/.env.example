APP_NAME=AgenticOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
AGENT_SYSTEM_PROMPT=你是 AgenticOS 的 AI 助手。
AGENT_MAX_STEPS=10
AGENT_PARALLEL_TOOL_CALLS=false
DATABASE_URL=sqlite:///./data/agenticos.db
SKILL_STORAGE_DIR=./data/skills
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESS_AFTER_TURNS=16
CONTEXT_KEEP_RECENT_TURNS=6
HITL_ENABLED=true
HITL_REQUIRE_APPROVAL_TOOLS=file_to_md,run_skill_python_script
HITL_TIMEOUT_SECONDS=300
AUTH_SECRET_KEY=change-this-to-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=10080
